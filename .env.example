# Copy to ".env" and fill in your own values, or export these in your shell.
# The CLAPS LLM components call one OpenAI-compatible chat-completions endpoint.

# --- Public OpenAI API (GPT-4o mini, as used in the paper) ---
CLAPS_LLM_API_URL=https://api.openai.com/v1/chat/completions
CLAPS_LLM_API_KEY=sk-your-key-here
CLAPS_LLM_AUTH=bearer

# --- Or any OpenAI-compatible proxy that takes the key in an "apikey" header ---
# CLAPS_LLM_API_URL=https://your-proxy/llm/openai/chat/completions/gpt-4o-mini/create
# CLAPS_LLM_API_KEY=your-proxy-key
# CLAPS_LLM_AUTH=apikey
